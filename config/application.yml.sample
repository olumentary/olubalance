# Optional — rotate Devise tokens independently of secret_key_base.
DEVISE_SECRET_KEY:

# Number of days a trusted-device cookie remains valid after passing 2FA.
# Clamped between 1 and 90; default 14.
TWO_FACTOR_REMEMBER_DAYS: 14

# Redis URL used by Rails cache (Rack::Attack counters live here in prod),
