<%= turbo_frame_tag "account_card_#{account.id}" do %>
  <div class="card has-equal-height account-card" id="account-card-<%= account.id %>">
    <%= link_to(account_transactions_path(account.id), data: { turbo_frame: "_top" }) do %>
      <%= render partial: "accounts/components/accountCardContent", locals: { account: account } %>
    <% end %>

    <footer class="card-footer">
      <span class="card-footer-item has-text-weight-medium has-text-grey"><%= account.last_four_display %></span>
      <%= link_to "Edit", edit_account_path(account), class: "card-footer-item has-text-weight-bold", data: { turbo_frame: "_top" } %>
    </footer>
  </div>
<% end %>
